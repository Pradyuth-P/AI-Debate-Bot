# ============================================
# AI Debate Bot - Backend Environment Variables
# ============================================

# OpenAI API Configuration (REQUIRED)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model Selection
# Options: gpt-4o-mini (faster/cheaper), gpt-4o (more powerful), gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# Token & Generation Settings
MAX_TOKENS=1000
TEMPERATURE=0.8

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Session Management
SESSION_TTL_HOURS=2
